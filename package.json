{
  "name": "eulr",
  "version": "0.1.0",
  "description": "Minimal terminal-first AI coding agent",
  "type": "module",
  "bin": {
    "eulr": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/codex-protocol.md",
    "docs/tui-architecture.md",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "clean": "node scripts/clean-dist.mjs",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "postbuild": "node scripts/make-bin-executable.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write ."
  },
  "keywords": [
    "ai",
    "coding-agent",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "diff": "8.0.2",
    "ink": "7.1.0",
    "openai": "^6.46.0",
    "react": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
